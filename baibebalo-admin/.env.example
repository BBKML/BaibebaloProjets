# URL de l'API Baibebalo (backend)
# En dev : utilisez l'IP affichée au démarrage du backend (🌐 URL réseau: http://192.168.1.X:5000)
# Exemple: VITE_API_URL=http://192.168.1.13:5000/api/v1 et VITE_BACKEND_URL=http://192.168.1.13:5000
# Pour build de production : mettre l'URL publique de votre API
VITE_API_URL=https://baibebaloprojets.onrender.com/api/v1
VITE_BACKEND_URL=https://baibebaloprojets.onrender.com
